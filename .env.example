# === Tailscale Configuration ===
# Hostname for this node on your tailnet (appears in the Tailscale admin console)
TS_HOSTNAME=embedder

# Tag for ACL policy (without the "tag:" prefix)
TS_TAG=embedder

# === Vault Secret Source (for Tailscale OAuth creds) ===
# Vault HTTPS endpoint and KVv2 path that stores ts_client_id + ts_client_secret.
VAULT_ADDR=https://100.76.91.69:8200
VAULT_SKIP_VERIFY=true
VAULT_TOKEN_FILE=${HOME}/.vault-token
VAULT_SECRET_PATH=kv/app/embeddercrux/prod

# === TEI Configuration ===
# HuggingFace model ID used for embeddings
MODEL_ID=nomic-ai/nomic-embed-text-v1.5

# TEI image tag; choose for your GPU architecture:
#   cuda-1.9   — broad CUDA build (recommended default when unsure)
#   89-1.9     — Ada Lovelace (RTX 4000 Ada, RTX 4090, L4)
#   86-1.9     — Ampere 8.6 (A10G, A40, selected RTX 30-series) / legacy default in older docs
#   1.9        — Ampere 8.0 (A100, A30)
#   hopper-1.9 — Hopper-optimized build
#   turing-1.9 — Turing (RTX 2000 series, T4)
#   cpu-1.9    — CPU only (slow, useful for testing)
TEI_IMAGE_TAG=cuda-1.9

# CPU-only fallback image used by scripts/compose-up-from-vault.sh when GPU startup fails.
TEI_CPU_IMAGE_TAG=cpu-1.9

# If true, launcher script automatically falls back to CPU TEI when GPU TEI fails startup/health.
ALLOW_CPU_FALLBACK=true

# If true, force a GPU attempt even when the launcher detects a likely-unsupported GPU/image pairing.
# Keep false on Blackwell/SM 12.x hosts unless you are supplying a custom TEI image that supports them.
ALLOW_UNSUPPORTED_GPU_ATTEMPT=false

# Seconds to wait for TEI /health before GPU startup is treated as failed.
TEI_HEALTH_TIMEOUT_SECONDS=300

# Max tokens per batch (higher generally improves throughput, at higher VRAM cost)
MAX_BATCH_TOKENS=16384

# Max number of input strings accepted per /embed request.
MAX_CLIENT_BATCH_SIZE=64

# Max concurrent requests TEI will process
MAX_CONCURRENT_REQUESTS=512

# Optional local host bind for non-tailnet callers (for example Docker workloads on the same host).
EMBEDDER_LOCAL_BIND=127.0.0.1
EMBEDDER_HOST_PORT=8080
