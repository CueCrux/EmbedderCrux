# === Tailscale Configuration ===
# Hostname for this node on your tailnet (appears in the Tailscale admin console)
TS_HOSTNAME=embedder

# Tag for ACL policy (without the "tag:" prefix)
TS_TAG=embedder

# === TEI Configuration ===
# HuggingFace model ID used for embeddings
MODEL_ID=nomic-ai/nomic-embed-text-v1.5

# TEI image tag; choose for your GPU architecture:
#   89-1.9     — Ada Lovelace (RTX 4000 Ada, RTX 4090, L4)
#   86-1.9     — Ampere 8.6 (A10G, A40, selected RTX 30-series) / legacy default in older docs
#   1.9        — Ampere 8.0 (A100, A30)
#   cuda-1.9   — Blackwell / Hopper (RTX PRO 6000, H100, etc.)
#   turing-1.9 — Turing (RTX 2000 series, T4)
#   cpu-1.9    — CPU only (slow, useful for testing)
TEI_IMAGE_TAG=89-1.9

# Max tokens per batch (higher generally improves throughput, at higher VRAM cost)
MAX_BATCH_TOKENS=16384

# Max concurrent requests TEI will process
MAX_CONCURRENT_REQUESTS=512
