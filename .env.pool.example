# === Pool Router Configuration ===

# Listen port for the pool router (Engine points EMBEDDERCRUX_BASE_URL here)
POOL_ROUTER_PORT=8079

# Static bootstrap targets (comma-separated URLs). Always included regardless
# of Tailscale discovery. Use for known nodes or when TS discovery is unavailable.
# Example: http://100.111.227.102:8080,http://10.80.0.2:8080
POOL_TARGETS=

# Health check polling interval (ms)
POOL_HEALTH_INTERVAL_MS=5000

# Health check timeout (ms) — should be short to avoid blocking the poll loop
POOL_HEALTH_TIMEOUT_MS=2000

# Consecutive failures before marking a node unhealthy
POOL_UNHEALTHY_THRESHOLD=3

# Nodes within this latency band (ms) of the fastest are round-robined
POOL_LATENCY_BAND_MS=20

# Timeout for proxied embed requests (ms)
POOL_REQUEST_TIMEOUT_MS=30000

# Max request body size (bytes) — should match gateway's EMBEDDER_BODY_LIMIT_BYTES
POOL_BODY_LIMIT_BYTES=8388608

# === Tailscale Auto-Discovery ===

# How often to poll `tailscale status --json` for new peers (ms)
POOL_DISCOVERY_INTERVAL_MS=30000

# Tag to filter Tailscale peers by (include the "tag:" prefix)
POOL_DISCOVERY_TAG=tag:embedder

# Port that embedder gateways listen on (appended to discovered Tailscale IPs)
POOL_DISCOVERY_PORT=8080

# === Tailscale Sidecar ===
# The pool router joins with tag:infra (not tag:embedder) to match ACL rules.

# Hostname for this node on your tailnet
TS_HOSTNAME=embedder-pool

# Tag for ACL policy (without the "tag:" prefix)
TS_TAG=infra

# === Vault Secret Source (for Tailscale OAuth creds) ===
VAULT_ADDR=https://100.76.91.69:8200
VAULT_SKIP_VERIFY=true
VAULT_TOKEN_FILE=${HOME}/.vault-token
VAULT_SECRET_PATH=kv/app/embeddercrux/prod

# === Host Binding ===
# Local bind address and port for non-tailnet callers (Engine on same host)
POOL_LOCAL_BIND=127.0.0.1
POOL_HOST_PORT=8079
